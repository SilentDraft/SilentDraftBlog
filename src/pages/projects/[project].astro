---
import "../../styles/article.css";
import "markdown-it-github-alerts/styles/github-base.css";
import "markdown-it-github-alerts/styles/github-colors-dark-media.css";
import Card from "../../components/Card.astro";
import Icon from "../../components/Icon.astro";
import Layout from "../../layouts/Layout.astro";
import { getProjectBySlug } from "../../lib/db/repos/projects";
import { renderMarkdown } from "../../lib/markdown";

const { project: projectId } = Astro.params;
const found = projectId ? await getProjectBySlug(projectId) : null;

if (!found) {
	return Astro.redirect("/404");
}

const project = found;
const html = await renderMarkdown(project.body);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<Layout
        title={project.title}
        description={project.description}
        image={project.image}
        article={{
                createdAt: project.date,
        }}
>
        <div class="left" slot="left">
                <Card class="toc-card">
                        <h2 class="no-mt">정보</h2>
                        <ul class="overview-list">
                                {
                                        project.info.map((info) => {
                                                const Tag = info.link ? "a" : "div";
                                                return (
                                                        <li>
                                                                <Tag href={info.link} class="project-info-item">
                                                                        <Icon
                                                                                type={info.icon.type}
                                                                                name={info.icon.name as any}
                                                                                width={24}
                                                                                height={24}
                                                                                class="glow-icon"
                                                                        />
                                                                        <span>{info.text}</span>
                                                                </Tag>
                                                        </li>
                                                );
                                        })
                                }
                        </ul>
                </Card>
        </div>
        <article slot="right" data-pagefind-body>
                <Card>
                        <div class="article-header" id="_top" data-pagefind-ignore>
                                {
                                        project.image && (
                                                <img
                                                        class="article-image"
                                                        src={project.image}
                                                        alt={project.title}
                                                />
                                        )
                                }
                                <div class="header">
                                        <div>
                                                <h1 class="no-mt article-h1">{project.title}</h1>
                                        </div>
                                        <div class="article-info">
                                                <span>{project.date.toLocaleDateString()}</span>
                                        </div>
                                </div>
                        </div>
                        <div set:html={html} />
                        <hr class="end-of-article" />
                        <a href={`${base}/projects`} class="block-link" data-pagefind-ignore
                                >← 프로젝트로 돌아가기</a
                        >
                </Card>
        </article>
</Layout>
<style>
        .project-info-item {
                display: flex;
                align-items: center;
                gap: 1rem;
        }
</style>