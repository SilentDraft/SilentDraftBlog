---
import "../../styles/article.css";
import type { CollectionEntry } from "astro:content";
import { getCollection, render } from "astro:content";
import Card from "../../components/Card.astro";
import Icon from "../../components/Icon.astro";
import ImageGlow from "../../components/ImageGlow.astro";
import Layout from "../../layouts/Layout.astro";

const { project: projectId } = Astro.params;
const projects = await getCollection("projects");
const project = projects.find(
        (p) =>
                p.id === projectId ||
                p.filePath?.endsWith(`${projectId}.mdx`) ||
                p.filePath?.endsWith(`${projectId}.md`),
);

if (!project) {
        return Astro.redirect("/404");
}

const { Content } = await render(project);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<Layout
        title={project.data.title}
        description={project.data.description}
        image={project.data.image}
        article={{
                createdAt: project.data.date,
        }}
>
        <div class="left" slot="left">
                <Card class="toc-card">
                        <h2 class="no-mt">정보</h2>
                        <ul class="overview-list">
                                {
                                        project.data.info.map((info) => {
                                                const Tag = info.link ? "a" : "div";
                                                return (
                                                        <li>
                                                                <Tag href={info.link} class="project-info-item">
                                                                        <Icon
                                                                                type={info.icon.type}
                                                                                name={info.icon.name as any}
                                                                                width={24}
                                                                                height={24}
                                                                                class="glow-icon"
                                                                        />
                                                                        <span>{info.text}</span>
                                                                </Tag>
                                                        </li>
                                                );
                                        })
                                }
                        </ul>
                </Card>
        </div>
        <article slot="right" data-pagefind-body>
                <Card>
                        <div class="article-header" id="_top" data-pagefind-ignore>
                                {
                                        project.data.image && (
                                                <ImageGlow
                                                        quality={100}
                                                        class="article-image"
                                                        src={project.data.image}
                                                        alt={project.data.title}
                                                />
                                        )
                                }
                                <div class="header">
                                        <div>
                                                <h1 class="no-mt article-h1">{project.data.title}</h1>
                                        </div>
                                        <div class="article-info">
                                                <span>{project.data.date.toLocaleDateString()}</span>
                                        </div>
                                </div>
                        </div>
                        <Content />
                        <hr class="end-of-article" />
                        <a href={`${base}/projects`} class="block-link" data-pagefind-ignore
                                >← 프로젝트로 돌아가기</a
                        >
                </Card>
        </article>
</Layout>
<style>
        .project-info-item {
                display: flex;
                align-items: center;
                gap: 1rem;
        }
</style>