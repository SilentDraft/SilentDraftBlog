---
import Layout from "../layouts/Layout.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Layout
  title={"404"}
  description={"페이지를 찾을 수 없습니다."}
	pagefindIgnore
>
  <div class="notfound-container" slot="404">
    <h1 class="text-glow">404</h1>
    <p>페이지를 찾을 수 없습니다.</p>
    <a class="block-link" href={`${base}/`}>← 홈으로 돌아가기</a>
  </div>
</Layout>
<style>
  .notfound-container {
    display: flex;
    height: 80vh;
    justify-content: center;
    align-items: center;
    width: 100%;
    text-align: center;
    flex-direction: column;
  }

  .notfound-container h1 {
    font-size: 4rem;
    margin: 0;
  }

  .notfound-container p {
    font-size: 1.25em;
  }

  .block-link {
    margin-top: 1rem;
  }
</style>