---
import "../styles/index.css";

import { name, openGraph } from "spectre:globals";
import ProfilePicture from "../assets/pfp.png";
import Card from "../components/Card.astro";
import Icon from "../components/Icon.astro";
import ImageGlow from "../components/ImageGlow.astro";
import Layout from "../layouts/Layout.astro";
import {
	getPage,
	listQuickInfo,
	listSocials,
	listWorkExperience,
} from "../lib/db/repos/misc";
import { listPosts } from "../lib/db/repos/posts";
import { listProjects } from "../lib/db/repos/projects";
import { renderMarkdown } from "../lib/markdown";

const [posts, projects, about, workExperience, quickInfo, socials] =
	await Promise.all([
		listPosts(),
		listProjects(),
		getPage("about"),
		listWorkExperience(),
		listQuickInfo(),
		listSocials(),
	]);

const aboutHtml = about ? await renderMarkdown(about.body) : "";

const currentYear = new Date().getFullYear();
const age = currentYear - 2002 + 1;
const devYear = currentYear - 2021 + 1;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Layout
	title={openGraph.home.title || name}
	description={openGraph.home.description}
	pagefindIgnore
>
	<div class="layout-grid-left" slot="left">
		<Card class="flex-col-card">
			<ImageGlow
				quality={100}
				width={120}
				height={120}
				src={ProfilePicture}
				alt="A purple, minimalist looking ghost."
				loading="eager"
			/>
			<h2>{name}</h2>
			<ul class="overview-list">
				{
					quickInfo.map((info) => (
						<li>
							<Icon
								type={info.icon.type}
								name={info.icon.name as any}
								width={24}
								height={24}
								class="glow-icon"
							/>
							<span>{info.text === "__AGE__" ? `${age} years old` : info.text === "__DEV_YEAR__" ? `${devYear}th year developer` : info.text}</span>
						</li>
					))
				}
			</ul>
		</Card>
		<Card>
			<h3 class="no-mt">Socials</h3>
			<ul class="overview-list">
				{
					socials.map((item) => (
						<li>
							<a href={item.link} class="socials-link">
								<Icon
									type={item.icon.type}
									name={item.icon.name as any}
									width={24}
									height={24}
									class="glow-icon"
								/>
								<span>{item.text}</span>
							</a>
						</li>
					))
				}
			</ul>
		</Card>
	</div>
	<div class="layout-grid-right" slot="right">
		<Card>
			<div class="header-container">
				<Icon
					type="lucide"
					name="user"
					width={24}
					height={24}
					class="glow-icon"
				/>
				<h2>About me</h2>
			</div>
			<div class="prose" set:html={aboutHtml} />
		</Card>
		<Card>
			<div class="header-container">
				<Icon
					type="lucide"
					name="rss"
					width={24}
					height={24}
					class="glow-icon"
				/>
				<h2>Latest Posts</h2>
			</div>
			<div class="content-container">
				{
					posts.slice(0, 2).map((post) => (
						<a href={`${base}/blog/${post.slug}`} class="post-container">
							<div class="post-header">
								<h3>{post.title}</h3>
								<span class="post-date">
									{post.createdAt.toLocaleDateString()}
								</span>
							</div>
							<span>{post.description}</span>
						</a>
					))
				}
			</div>
		</Card>
		<Card>
			<div class="header-container">
				<Icon
					type="lucide"
					name="folder-git"
					width={24}
					height={24}
					class="glow-icon"
				/>
				<h2>Latest Projects</h2>
			</div>
			<div class="content-container">
				{
					projects.slice(0, 2).map((project) => (
						<a href={`${base}/projects/${project.slug}`} class="post-container">
							<div class="post-header">
								<h3>{project.title}</h3>
								<span class="post-date">
									{project.date.toLocaleDateString()}
								</span>
							</div>
							<span>{project.description}</span>
						</a>
					))
				}
			</div>
		</Card>
		<Card>
			<div class="header-container">
				<Icon
					type="lucide"
					name="briefcase-business"
					width={24}
					height={24}
					class="glow-icon"
				/>
				<h2>Work Experience</h2>
			</div>
			<div class="work-experience-container">
				{
					workExperience.map((entry) => (
						<div class="work-experience-entry">
							<span class="work-experience-duration">
								{entry.duration}
							</span>
							<h3 class="work-experience-company">{entry.company}</h3>
							<span class="work-experience-role">{entry.title}</span>
							<p class="work-experience-desc">{entry.description}</p>
						</div>
					))
				}
			</div>
		</Card>
	</div>
</Layout>
